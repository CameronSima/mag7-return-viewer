# Frontend build-time variables (Vite). For Cloudflare Pages, set these in the
# Pages project's build settings. For local dev they're optional: leave
# VITE_API_BASE_URL empty so API calls stay relative and use the Vite dev proxy.

# Absolute base URL of the API backend, no trailing slash (e.g. the Coolify
# API domain). Empty in dev. In the Pages build, set it to your API origin:
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Canonical site URL baked into the prerendered SEO pages + sitemap.xml. Set to
# your Pages domain in production, e.g.:
#   VITE_SITE_URL=https://example.com
VITE_SITE_URL=
