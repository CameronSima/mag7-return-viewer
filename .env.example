# Copy to .env and adjust. docker compose reads this automatically.
# On Coolify, set these as environment variables / build args on the service.

# Host port the app is published on for local `docker compose` runs. The app
# listens on 8000 inside the container; Coolify maps a domain to that directly.
HTTP_PORT=8080

# Absolute canonical site URL baked into prerendered SEO pages + sitemap.xml at
# build time. Set this to your real domain in production.
VITE_SITE_URL=http://localhost:8080

# Number of uvicorn worker processes. They share one warm cache via Redis.
WEB_CONCURRENCY=2

# Comma-separated allowed CORS origins. Empty by default: the SPA is served
# same-origin by the app, so CORS isn't needed. Set this only if you expose the
# API to a browser on a different origin.
CORS_ORIGINS=
