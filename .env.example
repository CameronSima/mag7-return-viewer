# Backend (API) configuration — docker compose reads this automatically.
# On Coolify, set these as environment variables on the service.

# Host port the API is published on for local `docker compose` runs. Coolify
# maps an API domain to the container's port 8000 directly.
HTTP_PORT=8000

# Number of uvicorn worker processes. They share one warm cache via Redis.
WEB_CONCURRENCY=2

# Comma-separated allowed CORS origins — your Cloudflare Pages domain(s). The
# frontend is served cross-origin from Pages, so this MUST include its origin(s)
# in production, e.g.:
#   CORS_ORIGINS=https://example.com,https://example.pages.dev
CORS_ORIGINS=http://localhost:5173
