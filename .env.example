# Backend (API) configuration — docker compose reads this automatically.
# On Coolify, set these as environment variables on the service.

# Host port the API is published on for local `docker compose` runs. Coolify
# maps an API domain to the container's port 8000 directly.
HTTP_PORT=8000

# Number of uvicorn worker processes. They share one warm cache via Redis.
WEB_CONCURRENCY=2

# Comma-separated allowed CORS origins — your Cloudflare frontend domain(s). The
# frontend is served cross-origin (Workers `*.workers.dev` or Pages `*.pages.dev`),
# so this MUST include its exact origin in production, e.g.:
#   CORS_ORIGINS=https://mag7-return-viewer.cjsima.workers.dev
CORS_ORIGINS=http://localhost:5173

# Optional regex for additional allowed origins, e.g. Cloudflare preview
# deployments with hashed subdomains. Leave unset to allow only CORS_ORIGINS:
#   CORS_ORIGIN_REGEX=https://([a-z0-9-]+-)?mag7-return-viewer\.cjsima\.workers\.dev
# CORS_ORIGIN_REGEX=
